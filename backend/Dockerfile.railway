# Para Railway: contexto de build = backend/ (Root Directory = backend).
# No se copia data/ porque está en la raíz del repo; el seed fallará al arrancar y se ignora.
FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY . .

EXPOSE 5000

CMD node scripts/wait-and-migrate.js && \
    (node seeds/seed_data.js 2>/dev/null || true) && \
    node src/index.js
